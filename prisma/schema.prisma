generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id
  passwordHash String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  settings  UserSettings?
  cards     Card[]
}

model UserSettings {
  userId          String   @id
  encryptedApiKey String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Card {
  id         String    @id @default(cuid())
  userId     String
  name       String
  company    String?
  template   String    @default("classic")
  colorScheme String    @default("forest")
  logoImage  String?
  jobTitle   String?
  address    String?
  notes      String?
  imageUrl   String?
  rawText    String?
  confidence Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phones   Phone[]
  emails   Email[]
  websites Website[]

  @@index([userId, name])
  @@index([userId, company])
}

model Phone {
  id        String   @id @default(cuid())
  cardId    String
  value     String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([value])
  @@index([cardId])
}

model Email {
  id        String   @id @default(cuid())
  cardId    String
  value     String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([value])
  @@index([cardId])
}

model Website {
  id        String   @id @default(cuid())
  cardId    String
  value     String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([value])
  @@index([cardId])
}
